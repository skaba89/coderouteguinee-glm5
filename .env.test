# ============================================================
# CodeRoute Guinée — Test environment (E2E + integration tests)
# ============================================================
# Used by:
#   - e2e/fixtures/test-users.ts (Playwright credentials)
#   - prisma/seed.ts (when NODE_ENV=test)
#
# Copy to .env.test.local for personal overrides.
# NEVER commit .env.test.local.
# ============================================================

# These must match what prisma/seed.ts creates in the test DB.
E2E_ADMIN_EMAIL="admin@coderoute-gn.org"
E2E_ADMIN_PASSWORD="TestAdmin@2024"
E2E_CANDIDAT_EMAIL="candidat@demo.gn"
E2E_CANDIDAT_PASSWORD="TestCandidat@2024"

# Seed passwords (used by `npm run db:seed` when running tests)
SEED_ADMIN_PASSWORD="TestAdmin@2024"
SEED_INSPECTOR_PASSWORD="TestInspecteur@2024"
SEED_CENTRE_PASSWORD="TestCentre@2024"
SEED_CANDIDAT_PASSWORD="TestCandidat@2024"
SEED_AUTO_ECOLE_PASSWORD="TestAutoEcole@2024"

# Test database (SQLite in-memory equivalent for tests)
DATABASE_URL="file:/home/z/my-project/db/test.db"

# Cryptographic secrets for tests (NOT for production — these are public)
SESSION_SECRET="test-session-secret-do-not-use-in-production-32chars"
JWT_SECRET="test-jwt-secret-do-not-use-in-production-32chars-x"
CSRF_SECRET="test-csrf-secret-do-not-use-in-production-32chars-xx"
CRON_SECRET="test-cron-secret-do-not-use-in-production-32chars"

# Disable real integrations in tests
SMS_PROVIDER="console"
MOMO_PROVIDER="mock"
SMTP_HOST=""
