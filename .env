CSRF_SECRET=coderoute-dev-csrf-secret-2026-change-in-production-please

# ─── Email (SMTP) — leave empty for console mode ───
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM_NAME=CodeRoute Guinée
SMTP_FROM_EMAIL=noreply@coderoute-gn.org
EMAIL_API_URL=
EMAIL_API_KEY=

# ─── SMS — leave provider as "console" for dev ───
SMS_PROVIDER=console
SMS_API_KEY=
SMS_SENDER_ID=CodeRoute
SMS_API_URL=

# ─── Mobile Money (Orange/MTN/Celcom) ───
ORANGE_MONEY_API_KEY=
ORANGE_MONEY_API_SECRET=
MTN_MONEY_API_KEY=
MTN_MONEY_API_SECRET=
CELCOM_MONEY_API_KEY=
CELCOM_MONEY_API_SECRET=

# ─── Seed passwords (for `npm run db:seed`) ───
