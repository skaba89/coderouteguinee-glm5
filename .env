DATABASE_URL=file:/home/z/my-project/db/custom.db

# ─── Session security — MUST be changed in production ─────
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
SESSION_SECRET=coderoute-guinee-session-secret-2024-change-in-production

# ─── CSRF protection — MUST be changed in production ──────
CSRF_SECRET=coderoute-csrf-secret-change-in-production

# ─── Seed passwords (optional — if not set, secure random passwords are generated) ──
# SEED_ADMIN_PASSWORD=Admin@2024
# SEED_INSPECTOR_PASSWORD=Inspect@2024
# SEED_CENTRE_PASSWORD=Centre@2024
# SEED_CANDIDAT_PASSWORD=Candidat@2024

# ─── Email (SMTP) — required for production notifications ─
# SMTP_HOST=smtp.your-provider.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=noreply@coderoute-gn.org
# SMTP_PASS=your_smtp_password
# SMTP_FROM_NAME=CodeRoute Guinée
# SMTP_FROM_EMAIL=noreply@coderoute-gn.org

# ─── Alternative: HTTP-based email API ────────────────────
# EMAIL_API_URL=https://api.your-email-provider.com/send
# EMAIL_API_KEY=your_email_api_key

# ─── SMS provider (orange | mtn | celcom | console) ──────
SMS_PROVIDER=console
# SMS_API_KEY=your_sms_api_key
# SMS_SENDER_ID=CodeRoute
# SMS_API_URL=https://api.your-sms-provider.com/send

# ─── Mobile Money: Orange Money API ───────────────────────
# ORANGE_MONEY_API_URL=https://api.orange.com/om/equity/v1
# ORANGE_MONEY_API_KEY=your_orange_api_key
# ORANGE_MONEY_WEBHOOK_SECRET=your_orange_webhook_secret

# ─── Mobile Money: MTN MoMo API ───────────────────────────
# MTN_MONEY_API_URL=https://ericssonbasicapi2.azure-api.net/collection/v1_2
# MTN_MONEY_API_KEY=your_mtn_api_key
# MTN_MONEY_WEBHOOK_SECRET=your_mtn_webhook_secret

# ─── Mobile Money: Celcom Money API ───────────────────────
# CELCOM_MONEY_API_URL=https://api.celcom-gn.com/payment/v1
# CELCOM_MONEY_API_KEY=your_celcom_api_key
# CELCOM_MONEY_WEBHOOK_SECRET=your_celcom_webhook_secret

# ─── Application ──────────────────────────────────────────
NODE_ENV=development
# NEXT_PUBLIC_APP_URL=https://coderoute-gn.org
