{
  "annotations": {"list": []},
  "description": "CodeRoute Guinée — Infrastructure (PostgreSQL, Redis, host CPU/RAM/disk, network)",
  "editable": true,
  "graphTooltip": 1,
  "id": null,
  "panels": [
    {
      "title": "PostgreSQL Status",
      "type": "stat",
      "gridPos": {"h": 5, "w": 4, "x": 0, "y": 0},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [{"expr": "pg_up", "legendFormat": "", "refId": "A"}],
      "fieldConfig": {
        "defaults": {
          "mappings": [{"options": {"0": {"text": "DOWN", "color": "red"}, "1": {"text": "UP", "color": "green"}}, "type": "value"}],
          "thresholds": {"mode": "absolute", "steps": [{"color": "red", "value": null}, {"color": "green", "value": 1}]}
        }
      },
      "options": {"colorMode": "background", "graphMode": "none"}
    },
    {
      "title": "Redis Status",
      "type": "stat",
      "gridPos": {"h": 5, "w": 4, "x": 4, "y": 0},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [{"expr": "redis_up", "legendFormat": "", "refId": "A"}],
      "fieldConfig": {
        "defaults": {
          "mappings": [{"options": {"0": {"text": "DOWN", "color": "red"}, "1": {"text": "UP", "color": "green"}}, "type": "value"}],
          "thresholds": {"mode": "absolute", "steps": [{"color": "red", "value": null}, {"color": "green", "value": 1}]}
        }
      },
      "options": {"colorMode": "background", "graphMode": "none"}
    },
    {
      "title": "DB Connections (%)",
      "type": "gauge",
      "gridPos": {"h": 5, "w": 4, "x": 8, "y": 0},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {
          "expr": "pg_stat_activity_count / pg_settings_max_connections * 100",
          "legendFormat": "",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0, "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "yellow", "value": 60},
              {"color": "red", "value": 85}
            ]
          }
        }
      }
    },
    {
      "title": "Redis Memory (%)",
      "type": "gauge",
      "gridPos": {"h": 5, "w": 4, "x": 12, "y": 0},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {
          "expr": "redis_memory_used_bytes / redis_memory_max_bytes * 100",
          "legendFormat": "",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0, "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "yellow", "value": 70},
              {"color": "red", "value": 90}
            ]
          }
        }
      }
    },
    {
      "title": "Host CPU (%)",
      "type": "gauge",
      "gridPos": {"h": 5, "w": 4, "x": 16, "y": 0},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {
          "expr": "(1 - avg(rate(node_cpu_seconds_total{mode=\"idle\"}[5m]))) * 100",
          "legendFormat": "",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0, "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "yellow", "value": 60},
              {"color": "red", "value": 85}
            ]
          }
        }
      }
    },
    {
      "title": "Host Memory (%)",
      "type": "gauge",
      "gridPos": {"h": 5, "w": 4, "x": 20, "y": 0},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {
          "expr": "(1 - (node_memory_MemAvailable_bytes / node_memory_MemTotal_bytes)) * 100",
          "legendFormat": "",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0, "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "yellow", "value": 70},
              {"color": "red", "value": 90}
            ]
          }
        }
      }
    },
    {
      "title": "Disk Space by Mountpoint (%)",
      "type": "bargauge",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 5},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {
          "expr": "(1 - (node_filesystem_avail_bytes{mountpoint!~\"/proc|/sys|/dev\"} / node_filesystem_size_bytes{mountpoint!~\"/proc|/sys|/dev\"})) * 100",
          "legendFormat": "{{mountpoint}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "yellow", "value": 70},
              {"color": "red", "value": 90}
            ]
          }
        }
      },
      "options": {"orientation": "horizontal", "displayMode": "gradient"}
    },
    {
      "title": "Network Throughput (RX/TX bytes/s)",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 5},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {
          "expr": "rate(node_network_receive_bytes_total{device!~\"lo|veth.*|docker.*\"}[5m])",
          "legendFormat": "RX {{device}}",
          "refId": "A"
        },
        {
          "expr": "rate(node_network_transmit_bytes_total{device!~\"lo|veth.*|docker.*\"}[5m])",
          "legendFormat": "TX {{device}}",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "Bps",
          "custom": {"drawStyle": "line", "lineInterpolation": "smooth", "fillOpacity": 10}
        }
      }
    },
    {
      "title": "PostgreSQL Query Rate (queries/s)",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 13},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {
          "expr": "sum(rate(pg_stat_database_xact_commit[5m]) + rate(pg_stat_database_xact_rollback[5m]))",
          "legendFormat": "queries/s",
          "refId": "A"
        },
        {
          "expr": "sum(rate(pg_stat_database_xact_rollback[5m]))",
          "legendFormat": "rollbacks/s",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "custom": {"drawStyle": "line", "lineInterpolation": "smooth", "fillOpacity": 10}
        }
      }
    },
    {
      "title": "Redis Operations/s",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 13},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {
          "expr": "sum(rate(redis_commands_processed_total[5m]))",
          "legendFormat": "ops/s",
          "refId": "A"
        },
        {
          "expr": "sum(rate(redis_keyspace_hits_total[5m]))",
          "legendFormat": "hits/s",
          "refId": "B"
        },
        {
          "expr": "sum(rate(redis_keyspace_misses_total[5m]))",
          "legendFormat": "misses/s",
          "refId": "C"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "custom": {"drawStyle": "line", "lineInterpolation": "smooth", "fillOpacity": 10}
        }
      }
    },
    {
      "title": "Container Status (all services)",
      "type": "table",
      "gridPos": {"h": 10, "w": 24, "x": 0, "y": 21},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {
          "expr": "up",
          "legendFormat": "{{job}}",
          "refId": "A",
          "format": "table",
          "instant": true
        }
      ],
      "transformations": [
        {
          "id": "organize",
          "options": {
            "excludeByName": {"Time": true, "__name__": true},
            "renameByName": {"Value": "Status", "job": "Service", "instance": "Instance"}
          }
        },
        {
          "id": "convertFieldType",
          "options": {
            "conversions": [
              {"destinationType": "string", "targetField": "Status",
               "destFormat": {"0": "DOWN", "1": "UP"}}
            ]
          }
        }
      ]
    },
    {
      "title": "Recent Alerts",
      "type": "alertlist",
      "gridPos": {"h": 10, "w": 24, "x": 0, "y": 31},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "options": {
        "showOptions": "current",
        "maxItems": 20,
        "sortOrder": 2,
        "stateFilter": {"firing": true, "pending": true, "no_data": false}
      }
    }
  ],
  "refresh": "30s",
  "schemaVersion": 39,
  "tags": ["coderoute", "infrastructure"],
  "time": {"from": "now-1h", "to": "now"},
  "timezone": "browser",
  "title": "CodeRoute Guinée — Infrastructure Dashboard",
  "uid": "coderoute-infra",
  "version": 1
}
