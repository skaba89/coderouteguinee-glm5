# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example
!.env.test

# vercel
.vercel


# typescript
*.tsbuildinfo
next-env.d.ts
local-*
.claude
.z-ai-config
*.log
dev.log
dev.out.log
test
prompt

server.log
# Skills directory
/skills/

# Backups (daily DB dumps — never commit)
/backups
/backups/*

# Load test results
/load-tests/results/

# Playwright reports (regenerated on each run)
/playwright-report/
/test-results/

# Agent scratch / generated artifacts (never commit)
/tool-results/
/agent-ctx/
/download/
/coderouteguinee/

# Local media uploads (audio narration mp3s — stored on object storage in prod)
/upload/

# Local SQLite dev database (PostgreSQL in prod)
/db/

# Compressed backups
*.tar.gz
*.tgz
*.zip