# ============================================================
# CodeRoute Guinée — Environment Variables Reference (Sprint 1)
# ============================================================
# Copy this file to .env and fill in your values.
# Lines starting with # are comments. Default values shown in [brackets].
#
# For production, run: bash scripts/generate-secrets.sh > .env.production
# This generates strong random secrets — you only need to fill in
# the integration credentials (DB, SMTP, Orange, MoMo).
# ============================================================

# ─── Database ─────────────────────────────────────────────
# SQLite (development):
DATABASE_URL="file:/home/z/my-project/db/custom.db"

# PostgreSQL (PRODUCTION — see docs/POSTGRESQL_MIGRATION.md):
# DATABASE_URL="postgresql://coderoute:CHANGE_ME@localhost:5432/coderoute?schema=public"

# PostgreSQL container password (used by docker-compose.production.yml)
POSTGRES_USER="coderoute"
POSTGRES_PASSWORD="CHANGE_ME_USE_openssl_rand_hex_32"
POSTGRES_DB="coderoute"

# ─── App ──────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NODE_ENV="development"

# ─── Authentication secrets (REQUIRED in production) ──────
# All three must be at least 32 chars. Generate with: openssl rand -hex 32
# In production, missing/short secrets will crash the app at boot time.
SESSION_SECRET=""
JWT_SECRET=""
CSRF_SECRET=""

# ─── Initial seed passwords (REQUIRED in production) ──────
# The seed script REFUSES to run in production unless these are set.
# Generate with: openssl rand -base64 24 | tr -dc 'A-Za-z0-9' | head -c 16
SEED_ADMIN_PASSWORD=""
SEED_INSPECTOR_PASSWORD=""
SEED_CENTRE_PASSWORD=""
SEED_CANDIDAT_PASSWORD=""
SEED_AUTO_ECOLE_PASSWORD=""

# ─── Bootstrap super-admin (one-time) ─────────────────────
# Used by scripts/bootstrap-admin.ts to create the first admin.
# DELETE these lines after first boot.
BOOTSTRAP_ADMIN_EMAIL="admin@coderoute-gn.org"
BOOTSTRAP_ADMIN_PASSWORD=""

# ─── E2E test credentials ─────────────────────────────────
# Read by e2e/fixtures/test-users.ts. NEVER hardcode in source.
E2E_ADMIN_EMAIL="admin@coderoute-gn.org"
E2E_ADMIN_PASSWORD=""
E2E_CANDIDAT_EMAIL="candidat@demo.gn"
E2E_CANDIDAT_PASSWORD=""

# ─── Email (SMTP) ─────────────────────────────────────────
# Leave blank to log emails to console (dev mode)
# Recommended: Brevo (free 300/day), Mailgun, AWS SES
SMTP_HOST=""
SMTP_PORT="587"
SMTP_SECURE="false"
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM_NAME="CodeRoute Guinée"
SMTP_FROM_EMAIL="noreply@coderoute-gn.org"

# Optional: HTTP-based email API (SendGrid, Mailgun, etc.)
EMAIL_API_URL=""
EMAIL_API_KEY=""

# ─── SMS ──────────────────────────────────────────────────
# Provider: "console" (dev, logs to stdout) | "orange" | "mtn" | "celcom"
SMS_PROVIDER="console"
SMS_SENDER_ID="CodeRoute"
SMS_API_KEY=""
SMS_API_URL=""

# ─── Orange SMS OAuth2 (Phase 29) ─────────────────────────
# Real integration with Orange Guinea SMS API.
# Sign up at https://developer.orange.com and create a "SMS API" subscription.
# Get the client_id & client_secret from your app dashboard.
# The sender address is the phone number Orange provisions (e.g. "tel:+224628000000").
# Leave blank to keep console mode.
ORANGE_SMS_CLIENT_ID=""
ORANGE_SMS_CLIENT_SECRET=""
ORANGE_SMS_SENDER_ADDRESS=""
ORANGE_SMS_API_BASE="https://api.orange.com"

# ─── Mobile Money ─────────────────────────────────────────
# Orange Money / MTN MoMo / Celcom Money credentials.
# See docs/MOBILE-MONEY-SETUP.md for sandbox accounts.
MOMO_PROVIDER="mock"  # mock | orange | mtn | celcom
MOMO_API_KEY=""
MOMO_API_SECRET=""
MOMO_MERCHANT_ID=""

# ─── Security ─────────────────────────────────────────────
# 2FA TOTP secret for super-admin accounts
TOTP_ISSUER="CodeRoute Guinée"

# ─── Rate Limiting ────────────────────────────────────────
RATE_LIMIT_MAX="100"
RATE_LIMIT_WINDOW_MS="60000"

# ─── PWA (Phase 27) ───────────────────────────────────────
NEXT_PUBLIC_APP_NAME="CodeRoute Guinée"
NEXT_PUBLIC_APP_SHORT_NAME="CodeRoute GN"

# ─── Cron endpoints ───────────────────────────────────────
# Required to call /api/cron/* endpoints. Generate a new one.
# In production, set up a host cron job:
#   0 2 * * * curl -H "Authorization: Bearer $CRON_SECRET" https://coderoute-gn.org/api/cron/notifications
CRON_SECRET=""

# ─── Backups ──────────────────────────────────────────────
# Path where daily DB backups are stored (cron'd by scripts/backup-cron.sh)
BACKUP_DIR="/var/backups/coderoute"
BACKUP_RETENTION_DAYS="30"

# ─── Optional: Sentry / Monitoring ────────────────────────
SENTRY_DSN=""
SENTRY_ENVIRONMENT="development"
