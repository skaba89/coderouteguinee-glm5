// ============================================================
// CodeRoute Guinée — Database Schema (PostgreSQL variant)
// Identical models to schema.prisma (SQLite) but uses PostgreSQL provider
// To activate: bash scripts/switch-db.sh postgres
// ============================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── User & Auth ────────────────────────────────────────────

model User {
  id              String   @id @default(cuid())
  email           String   @unique
  passwordHash    String
  nom             String
  prenom          String
  dateNaissance   String   // ISO date string
  numeroIdentite  String   @unique
  telephone       String
  ville           String
  region          String   @default("Conakry")
  categoriePermis String   @default("B")
  role            String   @default("candidat") // candidat | auto-ecole | centre-agree | administration | super-admin
  numeroUnique    String   @unique // GN-CODE-YYYY-XXXXXX
  langueMaternelle String  @default("fr")
  photo           String?
  actif           Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  // Relations
  examSessions    ExamSession[]
  bookings        Booking[]
  fraudAlerts     FraudAlert[]  @relation("FraudCandidate")

  @@index([email])
  @@index([numeroUnique])
  @@index([role])
}

// ─── Centre & Region ────────────────────────────────────────

model Centre {
  id          String   @id @default(cuid())
  nom         String
  ville       String
  region      String
  adresse     String
  capacite    Int      @default(30)
  telephone   String
  email       String
  actif       Boolean  @default(true)
  // Accreditation
  accredDateDebut  String?
  accredDateFin    String?
  accredStatut     String   @default("actif")
  accredScore      Float    @default(80.0)
  // Equipements (JSON string)
  equipements String?
  // Langues disponibles (JSON string array)
  languesDisponibles String @default("[\"fr\"]")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  examSessions ExamSession[]
  bookings     Booking[]
  fraudAlerts  FraudAlert[]  @relation("FraudCentre")

  @@index([region])
  @@index([ville])
}

// ─── Questions ──────────────────────────────────────────────

model Question {
  id            Int      @id @default(autoincrement())
  texte         String
  options       String
  bonneReponse  Int
  categorie     String
  difficulte    String   @default("facile")
  mediaType     String   @default("text")
  signImage     String?
  scenarioImage String?
  videoUrl      String?
  audioFr       String?
  explication   String
  points        Int      @default(1)
  tempsEstime   Int      @default(20)
  tags          String   @default("[]")
  actif         Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  reponses      Reponse[]

  @@index([categorie])
  @@index([actif])
}

// ─── Exam Session ───────────────────────────────────────────

model ExamSession {
  id              String   @id @default(cuid())
  candidatId      String
  centreId        String
  centreNom       String
  date            String
  heure           String
  langue          String   @default("fr")
  statut          String   @default("programme")
  score           Int?
  totalQuestions  Int      @default(40)
  dureeEffective  Int?
  dateInscription DateTime @default(now())
  ipAdresse       String?
  navigateur      String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  candidat        User         @relation(fields: [candidatId], references: [id])
  centre          Centre       @relation(fields: [centreId], references: [id])
  reponses        Reponse[]
  fraudAlerts     FraudAlert[]

  @@index([candidatId])
  @@index([centreId])
  @@index([statut])
  @@index([date])
}

// ─── Reponses ───────────────────────────────────────────────

model Reponse {
  id            String   @id @default(cuid())
  sessionId     String
  questionId    Int
  reponseDonnee Int
  correcte      Boolean
  tempsReponse  Int?
  createdAt     DateTime @default(now())

  session       ExamSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  question      Question    @relation(fields: [questionId], references: [id])

  @@unique([sessionId, questionId])
  @@index([sessionId])
}

// ─── Booking ────────────────────────────────────────────────

model Booking {
  id              String   @id @default(cuid())
  candidatId      String
  centreId        String
  centreNom       String
  region          String
  ville           String
  date            String
  heure           String
  langue          String   @default("fr")
  categoriePermis String   @default("B")
  montant         Int      @default(350000) // GNF — tarif réservation examen
  moyenPaiement   String   @default("mobile_money")
  numeroPaiement  String?
  referencePaiement String?
  statutPaiement  String   @default("en_attente")
  numeroConvocation String?
  qrCodeData      String?
  confirmee       Boolean  @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  candidat        User    @relation(fields: [candidatId], references: [id])
  centre          Centre  @relation(fields: [centreId], references: [id])

  @@index([candidatId])
  @@index([centreId])
  @@index([statutPaiement])
}

// ─── Fraud Alert ────────────────────────────────────────────

model FraudAlert {
  id          String   @id @default(cuid())
  type        String
  description String
  severity    String   @default("medium")
  status      String   @default("active")
  candidatId  String?
  centreId    String?
  sessionId   String?
  timestamp   DateTime @default(now())
  details     String?
  resolvedAt  DateTime?
  resolvedBy  String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  candidat    User?       @relation("FraudCandidate", fields: [candidatId], references: [id])
  centre      Centre?     @relation("FraudCentre", fields: [centreId], references: [id])
  session     ExamSession? @relation(fields: [sessionId], references: [id])

  @@index([status])
  @@index([severity])
  @@index([candidatId])
}

// ─── Daily Stats ────────────────────────────────────────────

model DailyStat {
  id        String   @id @default(cuid())
  date      String   @unique
  centreId  String?
  exams     Int      @default(0)
  passed    Int      @default(0)
  failed    Int      @default(0)
  cancelled Int      @default(0)
  avgScore  Float    @default(0)
  revenue   Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([date])
  @@index([centreId])
}

// ─── Course & Lessons ───────────────────────────────────────

model Course {
  id          String   @id @default(cuid())
  titre       String
  description String
  categorie   String
  status      String   @default("publie")
  imageCover  String?
  dureeTotale Int      @default(0)
  nbInscrits  Int      @default(0)
  rating      Float    @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  lessons     Lesson[]

  @@index([status])
  @@index([categorie])
}

model Lesson {
  id            String   @id @default(cuid())
  courseId      String
  titre         String
  description   String
  type          String   @default("text")
  contenu       String
  mediaUrl      String?
  signImage     String?
  scenarioImage String?
  duree         Int      @default(5)
  ordre         Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  course        Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@index([courseId])
  @@index([ordre])
}

// ─── Password Reset Token ──────────────────────────────────

model PasswordResetToken {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  used      Boolean  @default(false)
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([token])
  @@index([expiresAt])
}

// ─── Two-Factor Authentication ─────────────────────────────

model TwoFactorSecret {
  id           String   @id @default(cuid())
  userId       String   @unique
  secret       String   // Encrypted TOTP secret
  backupCodes  String   // JSON array of hashed backup codes
  enabled      Boolean  @default(false)
  verifiedAt   DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([userId])
}

// ─── Notification Log ──────────────────────────────────────

model NotificationLog {
  id          String   @id @default(cuid())
  userId      String?
  type        String   // email | sms
  template    String   // welcome | password_reset | exam_reminder | payment_confirmation
  recipient   String   // email address or phone number
  subject     String?
  body        String
  status      String   @default("pending") // pending | sent | failed
  provider    String?  // smtp | orange_sms | mtn_sms | console
  error       String?
  sentAt      DateTime?
  createdAt   DateTime @default(now())

  @@index([userId])
  @@index([status])
  @@index([type])
}

// ─── Audit Log ─────────────────────────────────────────────

model AuditLog {
  id          String   @id @default(cuid())
  eventType   String
  severity    String   @default("info")
  userId      String?
  userRole    String?
  targetId    String?
  targetType  String?
  description String
  details     String?
  ipAddress   String?
  userAgent   String?
  timestamp   DateTime @default(now())

  @@index([eventType])
  @@index([userId])
  @@index([targetId])
  @@index([severity])
  @@index([timestamp])
}

// ============================================================
// TarifConfig — Tarification dynamique des examens
// ============================================================
model TarifConfig {
  id              String   @id @default(cuid())
  cle             String   @unique
  libelle         String
  montant         Int
  categoriePermis String   @default("B")
  actif           Boolean  @default(true)
  note            String?
  modifiePar      String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([cle])
  @@index([categoriePermis])
}
